{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./packages/cli/template-sources/project/configs/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/screensets/*": ["./src/screensets/*"],
      "@cyberfabric/state": ["./packages/state/src/index.ts"],
      "@cyberfabric/state/*": ["./packages/state/src/*"],
      "@cyberfabric/layout": ["./packages/layout/src/index.ts"],
      "@cyberfabric/layout/*": ["./packages/layout/src/*"],
      "@cyberfabric/api": ["./packages/api/src/index.ts"],
      "@cyberfabric/api/*": ["./packages/api/src/*"],
      "@cyberfabric/i18n": ["./packages/i18n/src/index.ts"],
      "@cyberfabric/i18n/*": ["./packages/i18n/src/*"],
      "@cyberfabric/perf-telemetry": ["./packages/perf-telemetry/src/index.ts"],
      "@cyberfabric/perf-telemetry/*": ["./packages/perf-telemetry/src/*"],
      "@cyberfabric/framework": ["./packages/framework/src/index.ts"],
      "@cyberfabric/framework/*": ["./packages/framework/src/*"],
      "@cyberfabric/react": ["./packages/react/src/index.ts"],
      "@cyberfabric/react/*": ["./packages/react/src/*"],
      "@cyberfabric/studio": ["./packages/studio/src/index.ts"],
      "@cyberfabric/studio/*": ["./packages/studio/src/*"],
      "@cyberfabric/cli": ["./packages/cli/src/index.ts"],
      "@cyberfabric/cli/*": ["./packages/cli/src/*"]
    }
  },
  "include": ["src", "packages/*/src", "packages/cli/template-sources/layout-custom-uikit"],
  "exclude": ["packages/*/dist", "packages/*/__tests__", "packages/*/src/__tests__", "**/__tests__", "src/mfe_packages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
